# X-DevOps Environment Configuration
# Copy this file to .env and fill in your values

# Backend
DRY_RUN=true                        # Set false to execute real kubectl commands
API_HOST=0.0.0.0
API_PORT=8000

# Kubernetes (only needed when DRY_RUN=false)
KUBE_NAMESPACE=xdevops
KUBE_SERVICE_NAME=sample-app
KUBE_SCALE_REPLICAS=5

# Docker Hub (for CI/CD)
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m
